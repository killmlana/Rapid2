# AWS
AWS_REGION=us-west-2
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v1
BEDROCK_LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
OPENSEARCH_ENDPOINT=your-endpoint.us-west-2.aoss.amazonaws.com
OPENSEARCH_INDEX=papers
OPENSEARCH_EMBEDDING_DIM=1536

# Neptune
NEPTUNE_ENDPOINT=your-cluster.us-west-2.neptune.amazonaws.com
NEPTUNE_PORT=8182

# Services
GROBID_URL=http://localhost:8070
VILA_URL=http://127.0.0.1:8080

# Semantic Scholar (optional, for higher rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# Citation crawling
MAX_CITATION_DEPTH=1
MAX_CITED_PAPERS=10
