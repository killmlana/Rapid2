# AWS
AWS_REGION=us-west-2
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v1
BEDROCK_LLM_MODEL=anthropic.claude-sonnet-4-6

# OpenSearch — paper embeddings
OPENSEARCH_ENDPOINT=your-papers-domain.us-west-2.es.amazonaws.com
OPENSEARCH_INDEX=papers
OPENSEARCH_EMBEDDING_DIM=1536

# OpenSearch — Anna's Archive metadata
ANNAS_OPENSEARCH_ENDPOINT=your-annas-domain.us-west-2.es.amazonaws.com

# Neptune
NEPTUNE_ENDPOINT=your-cluster.us-west-2.neptune.amazonaws.com
NEPTUNE_PORT=8182

# Services (ECS Service Connect DNS)
GROBID_URL=http://grobid.rapid2.local:8070
VILA_URL=http://vila.rapid2.local:8080

# S3
S3_PAPERS_BUCKET=rapid2-papers-123456789012

# Semantic Scholar (optional, for higher rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# Citation crawling
MAX_CITATION_DEPTH=1
MAX_CITED_PAPERS=10
